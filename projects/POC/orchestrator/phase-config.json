    "editorial": { "agent_file": "agents/editorial-team.json", "lead": "editorial-lead", "planning_permission_mode": "plan" },
    "research":  { "agent_file": "agents/research-team.json",  "lead": "research-lead",  "planning_permission_mode": "plan" },
    "coding":    { "agent_file": "agents/coding-team.json",    "lead": "coding-lead",    "planning_permission_mode": "plan" }
