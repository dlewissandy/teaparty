# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local app state
.env
teaparty.db
teaparty.db-shm
teaparty.db-wal

# SQLite temporary files (WAL, shared memory) at any level
*.db-shm
*.db-wal
*.db-journal

# OS files
.DS_Store

# Claude Code
.claude/worktrees/

# TeaParty — machine-specific external project registry
.teaparty/management/external-projects.yaml

# TeaParty — agent runtime state (message databases, session files, memory)
.teaparty/management/agents/*/om-messages.db
.teaparty/management/agents/*/pm-messages.db
.teaparty/management/agents/*/proxy-messages.db
.teaparty/management/agents/*/config-messages.db
.teaparty/management/agents/*/.om-session-*
.teaparty/management/agents/*/.pm-session-*
.teaparty/management/agents/*/.proxy-session-*
.teaparty/management/agents/*/.proxy-confidence*
.teaparty/management/agents/*/.proxy-memory*
.teaparty/management/agents/*/.om-agents-*

# Generated Documents
output/
site/

# POC runtime projects (each has own .git; POC itself is tracked)
projects/*
!projects/.gitignore
!projects/POC/
projects/POC/MEMORY.md
.memory.db
INTENT.md

# Experiment results (collected data, not source)
experiments/results/
!experiments/results/.gitkeep

# Intake pipeline — generated data
intake/raw/
intake/digests/
intake/analysis/
intake/ideas/
intake/.state.json
intake/.channel-ids.json
intake/run.log

# Refinement pipeline — working artifacts
refinement/

# Audit pipeline — scratch findings
/audit/
/audit-issue/

# Triage scratch
/triage/
# Worktrees
.worktrees/
