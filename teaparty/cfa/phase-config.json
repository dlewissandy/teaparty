{
  "phases": {
    "intent": {
      "agent_file": "intent",
      "lead": "intent-lead",
      "permission_mode": "acceptEdits",
      "stream_file": ".intent-stream.jsonl",
      "artifact": "INTENT.md",
      "approval_state": "INTENT_ASSERT",
      "settings_overlay": {
        "permissions": {
          "allow": ["Write", "Edit", "WebFetch", "WebSearch", "mcp__teaparty-config__AskQuestion"]
        }
      }
    },
    "planning": {
      "agent_file": "uber",
      "lead": "project-lead",
      "permission_mode": "acceptEdits",
      "stream_file": ".plan-stream.jsonl",
      "artifact": "PLAN.md",
      "approval_state": "PLAN_ASSERT",
      "settings_overlay": {
        "permissions": {
          "allow": ["Write", "Edit", "WebFetch", "WebSearch", "mcp__teaparty-config__AskQuestion"],
          "deny": ["Task", "TaskOutput", "TaskStop", "SendMessage", "Agent"]
        }
      }
    },
    "execution": {
      "agent_file": "uber",
      "lead": "project-lead",
      "permission_mode": "acceptEdits",
      "stream_file": ".exec-stream.jsonl",
      "artifact": "WORK_SUMMARY.md",
      "approval_state": "WORK_ASSERT",
      "settings_overlay": {
        "permissions": {
          "allow": ["Write", "Edit", "Bash", "mcp__teaparty-config__AskQuestion"],
          "deny": ["Task", "TaskOutput", "TaskStop", "SendMessage", "Agent"]
        }
      }
    }
  },
  "teams": {
    "art":       { "agent_file": "art",       "lead": "art-lead",       "planning_permission_mode": "plan" },
    "writing":   { "agent_file": "writing",   "lead": "writing-lead",   "planning_permission_mode": "plan" },
    "editorial": { "agent_file": "editorial", "lead": "editorial-lead", "planning_permission_mode": "plan" },
    "research":  { "agent_file": "research",  "lead": "research-lead",  "planning_permission_mode": "plan" },
    "coding":    { "agent_file": "coding",    "lead": "coding-lead",    "planning_permission_mode": "plan" },
    "configuration": { "agent_file": "configuration", "lead": "configuration-lead", "planning_permission_mode": "plan", "execution_model": "direct" }
  },
  "stall_timeout_seconds": 1800,
  "max_dispatch_retries": 5
}
